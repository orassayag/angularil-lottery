{
  "name": "angularil-lottery",
  "version": "0.0.0",
  "description": "An Angular-based lottery system for Angular-IL meetup raffles featuring a Matrix-style animated text reveal that randomly selects winners from attendee lists with support for Hebrew and English names. Provides an interactive and visually engaging raffle experience for meetups and community events",
